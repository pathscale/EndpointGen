#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]

Config(
    definition: EndpointSchemaList(
        service_name: "s1",
        service_id: 1,
        endpoints: [
            EndpointSchemaElement(
                schema: (
                    name: "UserGetBalance",
                    code: 10100,
                    parameters: [],
                    returns: [
                        Field(
                            name: "data",
                            ty: Struct(
                                name: "Balance",
                                fields: [
                                    Field(name: "amount", ty: Float64),
                                ],
                            ),
                        ),
                    ],
                    stream_response: None,
                    description: "Get the user's current balance",
                    json_schema: (),
                    roles: ["UserRole::Superadmin"],
                ),
            ),
            EndpointSchemaElement(
                schema: (
                    name: "UserGetPosition",
                    code: 10200,
                    parameters: [
                        Field(name: "symbol", ty: Optional(String)),
                    ],
                    returns: [
                        Field(
                            name: "positions",
                            ty: Vec(
                                Struct(
                                    name: "Position",
                                    fields: [
                                        Field(name: "symbol", ty: String),
                                        Field(name: "size", ty: Float64),
                                        Field(name: "entry_price", ty: Float64),
                                    ],
                                ),
                            ),
                        ),
                    ],
                    stream_response: None,
                    description: "Get the user's open positions",
                    json_schema: (),
                    roles: ["UserRole::Superadmin", "UserRole::Support"],
                ),
            ),
            EndpointSchemaElement(
                schema: (
                    name: "UserSubscribePositions",
                    code: 10300,
                    parameters: [],
                    returns: [
                        Field(name: "subscription_id", ty: UUID),
                    ],
                    stream_response: Some(
                        Struct(
                            name: "PositionUpdate",
                            fields: [
                                Field(name: "symbol", ty: String),
                                Field(name: "size", ty: Float64),
                                Field(name: "entry_price", ty: Float64),
                                Field(name: "timestamp", ty: TimeStampMs),
                            ],
                        ),
                    ),
                    description: "Subscribe to position updates",
                    json_schema: (),
                    roles: ["UserRole::Superadmin"],
                ),
            ),
        ],
    ),
)
